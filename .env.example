# Postgres (Neon, Vercel Postgres, or local)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin authentication (server-only — never use VITE_ prefix for secrets)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Must be at least 32 characters — use a long random string in production
ADMIN_SESSION_SECRET=replace-with-a-random-string-at-least-32-chars

# Vercel: add the same variables in Project Settings → Environment Variables.
# Build uses Nitro's "vercel" preset by default (see vite.config.ts).
